<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find sim_bot)/description/inertial_macros.xacro"/>
    
  <xacro:macro name="left_wheel" params="name parent origin rpy">

    <joint name="${name}_joint" type="continuous">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin xyz="${origin}" rpy="${rpy}"/>
      <axis xyz="0 0 1"/>
    </joint>

    <link name="${name}">
      <visual>
        <geometry>
          <cylinder radius="0.08255" length="0.04"/>
        </geometry>
        <material name="blue"/>
      </visual>

      <collision>
        <geometry>
          <cylinder radius="0.08255" length="0.04"/>
        </geometry>
      </collision>

      <xacro:inertial_cylinder mass="0.1" radius="0.08255" length="0.04"/>
    </link>
  </xacro:macro>

  <xacro:macro name="right_wheel" params="name parent origin rpy">

    <joint name="${name}_joint" type="continuous">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin xyz="${origin}" rpy="${rpy}"/>
      <axis xyz="0 0 -1"/>
    </joint>

    <link name="${name}">
      <visual>
        <geometry>
          <cylinder radius="0.08255" length="0.04"/>
        </geometry>
        <material name="blue"/>
      </visual>

      <collision>
        <geometry>
          <cylinder radius="0.08255" length="0.04"/>
        </geometry>
      </collision>

      <xacro:inertial_cylinder mass="0.1" radius="0.08255" length="0.04"/>
    </link>
  </xacro:macro>

  <xacro:macro name="robot_core">

    <material name="white">
      <color rgba="1 1 1 1"/>
    </material>

    <material name="blue">
      <color rgba="0.2 0.2 1 1"/>
    </material>

    <xacro:property name="M_PI" value="3.1415926535897931"/>
    <xacro:property name="left_rear_wheel_pos" value="-0.1 0.175 0"/>
    <xacro:property name="right_rear_wheel_pos" value="-0.1 -0.175 0"/>
    <xacro:property name="left_front_wheel_pos" value="0.1 0.175 0"/>
    <xacro:property name="right_front_wheel_pos" value="0.1 -0.175 0"/>

    <link name="base_link">
      <inertial>
        <mass value="0.001"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <joint name="chassis_joint" type="fixed">
      <parent link="base_link"/>
      <child link="chassis"/>
      <origin xyz="0 0 0.05"/>
    </joint>

    <link name="chassis">
      <visual>
        <origin xyz="0 0 0.125"/>
        <geometry>
          <box size="0.3 0.3 0.25"/>
        </geometry>
        <material name="white"/>
      </visual>

      <collision>
        <origin xyz="0 0 0.125"/>
        <geometry>
          <box size="0.3 0.3 0.25"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0.125"/>
        <inertia ixx="0.015" ixy="0" ixz="0" iyy="0.0375" iyz="0" izz="0.0375"/>
      </inertial>
    </link>

  <xacro:left_wheel
    name="left_rear_wheel"
    parent="chassis"
    origin="${left_rear_wheel_pos}"
    rpy="${-(M_PI/2)} 0 0"/>

  <xacro:right_wheel
    name="right_rear_wheel"
    parent="chassis"
    origin="${right_rear_wheel_pos}"
    rpy="${M_PI/2} 0 0"/>

  <xacro:left_wheel
    name="left_front_wheel"
    parent="chassis"
    origin="${left_front_wheel_pos}"
    rpy="${-(M_PI/2)} 0 0"/>

  <xacro:right_wheel
    name="right_front_wheel"
    parent="chassis"
    origin="${right_front_wheel_pos}"
    rpy="${M_PI/2} 0 0"/>

    <gazebo reference="chassis">
      <material>Gazebo/White</material>
      <mu1>0.2</mu1>
      <mu2>0.2</mu2>
      <selfCollide>true</selfCollide>
    </gazebo>

    <gazebo reference="left_rear_wheel">
      <material>Gazebo/Blue</material>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <selfCollide>true</selfCollide>
    </gazebo>

    <gazebo reference="right_rear_wheel">
      <material>Gazebo/Blue</material>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <selfCollide>true</selfCollide>
    </gazebo>

    <gazebo reference="left_front_wheel">
      <material>Gazebo/Blue</material>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <selfCollide>true</selfCollide>
    </gazebo>

    <gazebo reference="right_front_wheel">
      <material>Gazebo/Blue</material>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <selfCollide>true</selfCollide>
    </gazebo>

  </xacro:macro>

</robot>